#!/bin/sh
# Show real Claude account usage (5-hour and weekly windows).
#
#   claude-usage           human readable
#   claude-usage --json    raw JSON
#   claude-usage --reset   local HH:MM when the 5-hour window resets (+90s margin),
#                          ready to feed into claude-auto-resume
set -eu

# Resolve lib/ whether we run in-place, via a PATH symlink, or from a plugin install.
self="$0"; link=$(readlink "$self" 2>/dev/null) && [ -n "$link" ] && case "$link" in
    /*) self="$link" ;; *) self="$(dirname "$self")/$link" ;;
esac
for d in "$(dirname "$self")/../lib" "${CLAUDE_PLUGIN_ROOT:-}/lib" "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/lib"; do
    [ -f "$d/usage.sh" ] && . "$d/usage.sh" && break
done
command -v cug_fetch >/dev/null 2>&1 || { echo "usage.sh not found" >&2; exit 1; }

json=$(cug_fetch) || exit 1

case "${1:-}" in
    --json)
        printf '%s\n' "$json"
        ;;
    --reset)
        # +90s margin: wake up after the reset, not a second before it
        iso=$(printf '%s' "$json" | cug_json_block five_hour | cug_json_str resets_at)
        epoch=$(cug_iso_epoch "$iso") || { echo "cannot parse reset time" >&2; exit 1; }
        cug_epoch_hhmm "$epoch" 90
        ;;
    "")
        for key in five_hour seven_day; do
            block=$(printf '%s' "$json" | cug_json_block "$key")
            [ -z "$block" ] && continue
            util=$(printf '%s' "$block" | cug_json_num utilization)
            iso=$(printf '%s' "$block" | cug_json_str resets_at)
            epoch=$(cug_iso_epoch "$iso") || epoch=""
            when=${epoch:+$(cug_epoch_hhmm "$epoch")}
            label="5 hours "; [ "$key" = seven_day ] && label="7 days  "
            printf '%s %5s%%   resets at %s\n' "$label" "$util" "${when:-?}"
        done
        ;;
    *)
        echo "usage: claude-usage [--json|--reset]" >&2; exit 1
        ;;
esac
